SHOPIFY_API_KEY=your_shopify_app_api_key
SHOPIFY_API_SECRET=your_shopify_app_api_secret
SHOPIFY_SCOPES=read_orders,read_products,write_inventory,read_inventory
SHOPIFY_OAUTH_REDIRECT_URI=https://us-central1-your-project.cloudfunctions.net/shopifyOAuthCallback
SHOPIFY_OAUTH_POST_AUTH_REDIRECT=http://localhost:5173
SHOPIFY_WEBHOOK_SECRET=shopify_webhook_secret_or_api_secret
SHOPIFY_API_VERSION=2025-10

# Optional legacy single-store fallback (if no OAuth stores exist).
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxx

# Optional fallback location for products without per-store location mapping.
SHOPIFY_LOCATION_ID=123456789

# Optional shared secret expected in x-sync-token headers.
SYNC_API_KEY=replace-with-shared-secret

# Optional sync throttling controls.
SHOPIFY_SYNC_BATCH_SIZE=20
SHOPIFY_SYNC_BATCH_DELAY_MS=250
SHOPIFY_REQUEST_DELAY_MS=120

# Optional Pub/Sub topic names for Shopify webhook delivery.
SHOPIFY_PUBSUB_TOPIC_ORDERS_CREATE=shopify-orders-create
SHOPIFY_PUBSUB_TOPIC_ORDERS_CANCELLED=shopify-orders-cancelled
SHOPIFY_PUBSUB_TOPIC_REFUNDS_CREATE=shopify-refunds-create
