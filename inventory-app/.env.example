VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456

# Local functions/emulator URL for sync/import actions:
# http://127.0.0.1:5001/<firebase-project-id>/us-central1
VITE_FUNCTIONS_BASE_URL=http://127.0.0.1:5001/your-project-id/us-central1

# Deployed/public functions URL used only for OAuth start/callback:
# https://us-central1-<firebase-project-id>.cloudfunctions.net
VITE_OAUTH_FUNCTIONS_BASE_URL=https://us-central1-your-project-id.cloudfunctions.net

# Must match SYNC_API_KEY in the functions environment.
VITE_SYNC_API_KEY=replace-with-shared-secret
